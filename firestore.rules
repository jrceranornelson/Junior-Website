rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /blog/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /gallery/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /music/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /academic/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /projects/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /about/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /social/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /messages/{id} {
      allow read, write: if true;
    }
    match /subscribers/{id} {
      allow read, write: if true;
    }
    match /_analytics/{id} {
      allow read: if request.auth != null;
      allow write: if true;
    }
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
